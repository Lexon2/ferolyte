{
  "compilerOptions": {
    "module": "ES2020",
    "target": "es2020",
    "lib": ["es2020"],
    "moduleResolution": "node",
    "rootDir": ".",
    "baseUrl": ".",
    "declaration": false,
    "noEmit": true,
    "noEmitHelpers": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": false,
    "pretty": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": false,
    "noImplicitUseStrict": false,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@artifex/common/*": ["packages/common/*"],
      "@artifex/pack/*": ["packages/pack/*"],
      "@artifex/cli/*": ["packages/cli/*"]
    }
  },
  "include": [
    "packages/common/**/*",
    "packages/pack/**/*",
    "packages/cli/**/*"
  ],
  "exclude": ["node_modules", "**/*.d.ts", "**/*.d.ts.map"]
}
