{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noCheck": true,
    "sourceMap": false,
    "rootDir": ".",
    "outDir": "./dist",
    "paths": {
      "@artifex/cli/*": ["./*"],
      "@artifex/common/*": ["../common/dist/*"],
      "@artifex/pack/*": ["../pack/dist/*"]
    }
  }
}
