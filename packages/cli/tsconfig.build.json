{
  "compilerOptions": {
    "module": "ES2020",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "rootDir": ".",
    "outDir": "./dist",
    "baseUrl": ".",
    "declaration": false,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@ferolyte/cli/*": ["./*"],
      "@ferolyte/common/*": ["../common/*"],
      "@ferolyte/pack/*": ["../pack/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.d.ts"]
}
