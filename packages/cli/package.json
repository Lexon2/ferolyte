{
  "name": "@ferolyte/cli",
  "version": "0.2.3",
  "description": "Ferolyte CLI and pack compiler for Minecraft BE addons",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lexon2/ferolyte.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Lexon2/ferolyte/issues"
  },
  "homepage": "https://github.com/Lexon2/ferolyte#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ferolyte": "./cli/index.js"
  },
  "exports": {
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js",
      "default": "./*.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.js.map",
    "**/*.d.ts.map"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ferolyte/common": "^0.2.3",
    "@ferolyte/pack": "^0.2.3",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "esbuild": "^0.28.1",
    "jsonc-parser": "^3.3.1",
    "uuid": "^13.0.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "minecraft",
    "minecraft-bedrock",
    "bedrock",
    "bedrock-edition",
    "addon",
    "addons",
    "minecraft-addon",
    "typescript",
    "cli",
    "compiler",
    "generator",
    "script-api",
    "watch",
    "mcaddon",
    "ferolyte"
  ],
  "engines": {
    "node": ">=18"
  }
}
