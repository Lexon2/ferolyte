{
  "name": "@artifex/pack",
  "version": "0.1.0",
  "description": "Artifex pack compiler and CLI for Minecraft BE addons",
  "license": "MIT",
  "type": "module",
  "main": "./dist/artifex-pack.js",
  "bin": {
    "artifex": "./dist/cli/index.js"
  },
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "esbuild": "^0.25.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
