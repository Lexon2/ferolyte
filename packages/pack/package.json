{
  "name": "@ferolyte/pack",
  "version": "0.1.0",
  "description": "Ferolyte content SDK for Minecraft BE addons",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lexon2/ferolyte.git",
    "directory": "packages/pack"
  },
  "bugs": {
    "url": "https://github.com/Lexon2/ferolyte/issues"
  },
  "homepage": "https://github.com/Lexon2/ferolyte#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ferolyte/common": "^0.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
