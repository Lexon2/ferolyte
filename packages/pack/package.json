{
  "name": "@ferolyte/pack",
  "version": "0.2.3",
  "description": "Ferolyte content SDK for Minecraft BE addons",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lexon2/ferolyte.git",
    "directory": "packages/pack"
  },
  "bugs": {
    "url": "https://github.com/Lexon2/ferolyte/issues"
  },
  "homepage": "https://github.com/Lexon2/ferolyte#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.js",
      "default": "./*.js"
    }
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.js.map",
    "**/*.d.ts.map"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ferolyte/common": "^0.2.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "minecraft",
    "minecraft-bedrock",
    "bedrock",
    "bedrock-edition",
    "addon",
    "addons",
    "minecraft-addon",
    "mcaddon",
    "typescript",
    "sdk",
    "content",
    "blocks",
    "items",
    "entities",
    "ferolyte"
  ],
  "engines": {
    "node": ">=18"
  }
}
