{
  "name": "ferolyte",
  "private": true,
  "license": "MIT",
  "version": "0.1.0",
  "description": "Craft your Minecraft BE addons easialy with Ferolyte framework.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lexon2/ferolyte.git"
  },
  "bugs": {
    "url": "https://github.com/Lexon2/ferolyte/issues"
  },
  "homepage": "https://github.com/Lexon2/ferolyte#readme",
  "workspaces": [
    "packages/common",
    "packages/pack",
    "packages/cli"
  ],
  "overrides": {
    "minimatch@3.1.5": {
      "brace-expansion": "1.1.13"
    }
  },
  "scripts": {
    "postinstall": "npm run build:packages",
    "build:packages": "npm run build -w @ferolyte/common && npm run build -w @ferolyte/pack && npm run build -w @ferolyte/cli",
    "pack:check": "npm run build:packages && npm run verify:cli && npm pack -w @ferolyte/common --dry-run && npm pack -w @ferolyte/pack --dry-run && npm pack -w @ferolyte/cli --dry-run",
    "verify:cli": "node scripts/verify-cli-package.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build:packages && changeset publish",
    "lint": "eslint \"./packages/**/*.ts\"",
    "lint:fix": "eslint \"./packages/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@minecraft/server": "^2.6.0",
    "@minecraft/server-ui": "2.0.0",
    "@minecraft/vanilla-data": "^1.26.20"
  },
  "devDependencies": {
    "@ferolyte/cli": "workspace:*",
    "@ferolyte/common": "workspace:*",
    "@ferolyte/pack": "workspace:*",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import-x": "^4.10.3",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.29.0",
    "vitest": "^4.1.8"
  }
}
