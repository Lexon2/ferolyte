{
  "name": "@artifex",
  "license": "MIT",
  "version": "0.1.0",
  "description": "Craft your Minecraft BE addons easialy with Artifex framework.",
  "main": "src/main.ts",
  "type": "module",
  "workspaces": [
    "packages/common",
    "packages/pack",
    "packages/cli"
  ],
  "scripts": {
    "build:packages": "npm run build -w @artifex/common && npm run build -w @artifex/pack && npm run build -w @artifex/cli",
    "lint": "eslint \"./packages/**/*.ts\"",
    "lint:fix": "eslint \"./packages/**/*.ts\" --fix",
    "artifex:build": "artifex run",
    "artifex:watch": "artifex watch",
    "artifex:watch:development": "artifex watch development",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@minecraft/debug-utilities": "^1.0.0-beta.1.21.102-stable",
    "@minecraft/server": "^2.6.0",
    "@minecraft/server-ui": "2.0.0",
    "@minecraft/vanilla-data": "^1.26.20",
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.2"
  },
  "devDependencies": {
    "@artifex/cli": "*",
    "@artifex/common": "*",
    "@artifex/pack": "*",
    "@eslint/config-array": "^0.20.0",
    "@eslint/js": "^9.24.0",
    "@eslint/object-schema": "^2.1.6",
    "@stylistic/eslint-plugin-ts": "^4.2.0",
    "@types/dotenv": "^6.1.1",
    "@typescript-eslint/parser": "^8.29.0",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import-x": "^4.10.3",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.2.4",
    "source-map": "^0.7.4",
    "strip-json-comments": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.29.0",
    "uuid": "^13.0.0",
    "vitest": "^3.2.4",
    "ws": "^8.18.3"
  }
}
